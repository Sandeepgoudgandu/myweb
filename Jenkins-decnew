pipeline {
    agent any

    tools {
        maven 'Maven-3.6.1'
    }

    environment {
        IMAGE_NAME = "sandeepgoudgandu/spring-boot-mongo:${BUILD_NUMBER}"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Git Checkout') {
            steps {
                git branch: 'master',
                    credentialsId: 'javahome2',
                    url: 'https://github.com/Sandeepgoudgandu/myweb.git'
            }
        }
        
         stage('Gitleaks Secret Scan') {
            steps {
                sh '''
                gitleaks detect --source . --report-format json --report-path gitleaks-report.json || true
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh '''
                    mvn clean verify sonar:sonar \
                    -Dsonar.projectKey=myweb \
                    -Dsonar.projectName=myweb
                    '''
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
               dependencyCheck(
    odcInstallation: 'DP-Check',
    additionalArguments: '--scan . --noupdate'
)
            }
        }

        stage('Maven Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Upload WAR To Nexus') {
            steps {
                nexusArtifactUploader(
                    nexusVersion: 'nexus3',
                    protocol: 'http',
                    nexusUrl: '172.31.3.129:8081',
                    groupId: 'in.javahome',
                    version: '8.2.0',
                    repository: 'sample-releases',
                    credentialsId: 'nexus3',
                    artifacts: [[
                        artifactId: 'myweb',
                        classifier: '',
                        file: 'target/myweb-8.2.0.war',
                        type: 'war'
                    ]]
                )
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t $IMAGE_NAME .
                docker tag $IMAGE_NAME sandeepgoudgandu/spring-boot-mongo:latest
                '''
            }
        }

        stage('Trivy File System Scan') {
            steps {
                sh '''
                trivy fs . \
                --severity HIGH,CRITICAL \
                -o trivy-fs-report.txt
                '''
            }
        }

        stage('Trivy Docker Image Scan') {
            steps {
                sh '''
                trivy image $IMAGE_NAME \
                --severity HIGH,CRITICAL \
                -o trivy-image-report.txt
                '''
            }
        }

        stage('Archive Security Reports') {
            steps {
                archiveArtifacts artifacts: '*.txt', fingerprint: true
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([
                    string(
                        credentialsId: 'DOCKER_HUB_CREDENTIALS',
                        variable: 'DOCKER_HUB_TOKEN'
                    )
                ]) {
                    sh '''
                    echo "$DOCKER_HUB_TOKEN" | docker login -u sandeepgoudgandu --password-stdin

                    docker push $IMAGE_NAME
                    docker push sandeepgoudgandu/spring-boot-mongo:latest
                    '''
                }
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                docker rm -f myweb || true

                docker run -d \
                --name myweb \
                -p 9090:8080 \
                $IMAGE_NAME
                '''
            }
        }
    }

    post {

        success {
            echo 'DevSecOps Pipeline Executed Successfully'
        }

        failure {
            echo 'DevSecOps Pipeline Failed'
        }

        always {
            cleanWs()
        }
    }
}
