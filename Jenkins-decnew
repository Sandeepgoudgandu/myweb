pipeline{
    agent any

    tools {
        maven 'Maven-3.6.1'
    }

    environment{
        PATH = "/opt/maven3/bin:$PATH"
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages{

        stage("Clean Workspace"){
            steps{
                cleanWs()
            }
        }

        stage("Git Checkout"){
            steps{
                git credentialsId: 'javahome2',
                url: 'https://github.com/Sandeepgoudgandu/myweb.git'
            }
        }

        stage("SonarQube Analysis"){
            steps{
                withSonarQubeEnv('sonar-server') {

                    sh """
                    mvn clean verify sonar:sonar \
                    -Dsonar.projectKey=myweb \
                    -Dsonar.projectName=myweb
                    """
                }
            }
        }

        stage("Quality Gate"){
            steps{
                waitForQualityGate abortPipeline: true
            }
        }

        stage("Maven Build"){
            steps{
                sh "mvn clean package -DskipTests"
            }
        }

        stage("OWASP Dependency Check"){
            steps{
                dependencyCheck additionalArguments: '--scan ./',
                odcInstallation: 'DP-Check'

                dependencyCheckPublisher pattern:
                '**/dependency-check-report.xml'
            }
        }

        stage('Upload War To Nexus'){
            steps{

                nexusArtifactUploader artifacts: [
                    [
                        artifactId: 'myweb',
                        classifier: '',
                        file: "target/myweb-8.2.0.war",
                        type: 'war'
                    ]
                ],
                credentialsId: 'nexus3',
                groupId: 'in.javahome',
                nexusUrl: '172.31.42.75:8081',
                nexusVersion: 'nexus3',
                protocol: 'http',
                repository: 'sample-releases',
                version: '8.2.0'
            }
        }

        stage('Build Docker Image'){
            steps{

                sh 'docker build -t sandeepgoudgandu/spring-boot-mongo .'

                sh 'docker build -t tomcat:${BUILD_NUMBER} .'
            }
        }

        stage('Trivy File System Scan'){
            steps{
                sh 'trivy fs . > trivy-fs-report.txt'
            }
        }

        stage('Trivy Docker Image Scan'){
            steps{
                sh 'trivy image tomcat:${BUILD_NUMBER} > trivy-image-report.txt'
            }
        }

        stage('Deploy Container'){
            steps{

                sh '''
                docker rm -f vani || true
                docker run -itd \
                --name vani \
                -p 9090:8080 \
                tomcat:${BUILD_NUMBER}
                '''
            }
        }

        stage('Push Docker Image'){
            steps{

                withCredentials([
                    string(
                        credentialsId: 'DOCKER_HUB_CREDENTIALS1',
                        variable: 'DOCKER_HUB_CREDENTIALS'
                    )
                ]) {

                    sh """
                    docker login -u sandeepgoudgandu \
                    -p ${DOCKER_HUB_CREDENTIALS}
                    """

                    sh 'docker push sandeepgoudgandu/spring-boot-mongo'
                }
            }
        }
    }

    post{

        success{
            echo 'DevSecOps Pipeline Executed Successfully'
        }

        failure{
            echo 'Pipeline Failed'
        }
    }
}
